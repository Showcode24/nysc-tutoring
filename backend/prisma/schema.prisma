// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserType {
  TUTOR
  ADMIN
}

enum TutorStatus {
  REGISTERED_RESTRICTED
  CHECKED_IN
  ACTIVE
  REJECTED
}

enum AdminRole {
  FRONT_DESK
  MANAGER
  SUPER_ADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

enum DocumentType {
  GOVERNMENT_ID
  CERTIFICATE
  DEGREE
  OTHER
}

enum AuditAction {
  TUTOR_REGISTERED
  TUTOR_CHECKED_IN
  TUTOR_APPROVED
  TUTOR_REJECTED
  APPOINTMENT_SCHEDULED
  APPOINTMENT_COMPLETED
  DOCUMENT_UPLOADED
  STATUS_CHANGED
  ADMIN_CREATED
  ADMIN_DELETED
}

// ==================== CORE TABLES ====================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  userType          UserType
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  tutor             Tutor?
  admin             Admin?

  @@index([email])
  @@index([userType])
}

model Tutor {
  id                String            @id @default(cuid())
  userId            String            @unique
  status            TutorStatus       @default(REGISTERED_RESTRICTED)
  specialization    String
  yearsOfExperience Int
  hourlyRate        Float
  bio               String?
  profileImage      String?
  documents         TutorDocument[]
  appointments      Appointment[]
  statusHistory     TutorStatusHistory[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([specialization])
}

model Admin {
  id                String            @id @default(cuid())
  userId            String            @unique
  role              AdminRole
  department        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  auditLogs         AdminActionLog[]

  @@index([role])
}

model TutorDocument {
  id                String            @id @default(cuid())
  tutorId           String
  documentType      DocumentType
  fileName          String
  fileUrl           String
  uploadedAt        DateTime          @default(now())
  verifiedAt        DateTime?
  verifiedBy        String?
  verified          Boolean           @default(false)

  tutor             Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([documentType])
  @@index([verified])
}

model Appointment {
  id                String            @id @default(cuid())
  tutorId           String
  adminId           String
  status            AppointmentStatus @default(SCHEDULED)
  scheduledAt       DateTime
  completedAt       DateTime?
  location          String?
  notes             String?
  checkedInAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tutor             Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  admin             Admin             @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([tutorId])
  @@index([adminId])
  @@index([status])
  @@index([scheduledAt])
}

// ==================== AUDIT & HISTORY ====================

model TutorStatusHistory {
  id                String            @id @default(cuid())
  tutorId           String
  oldStatus         TutorStatus?
  newStatus         TutorStatus
  changedBy         String?
  reason            String?
  changedAt         DateTime          @default(now())

  tutor             Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorId])
  @@index([changedAt])
  @@index([newStatus])
}

model AdminActionLog {
  id                String            @id @default(cuid())
  adminId           String
  action            AuditAction
  targetType        String            // e.g., "Tutor", "Appointment"
  targetId          String
  details           String?           // JSON stringified
  ipAddress         String?
  userAgent         String?
  performedAt       DateTime          @default(now())

  admin             Admin             @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
  @@index([performedAt])
}

// ==================== GIGS (Future) ====================

model Gig {
  id                String            @id @default(cuid())
  title             String
  description       String
  subject           String
  level             String            // e.g., HIGH_SCHOOL, COLLEGE, ADULT
  hourlyRate        Float
  startDate         DateTime
  endDate           DateTime?
  maxTutors         Int               @default(1)
  status            String            @default("OPEN") // OPEN, ASSIGNED, COMPLETED
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([subject])
  @@index([startDate])
}
